# Apocalypse Blox Hub — environment variables.
# Copy to .env for local dev and set the same keys in Vercel for production.
# NEVER commit a real .env (it's gitignored). Values below are placeholders.

# ===== Supabase =====
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret   # server-only, keep private

# ===== Auth =====
NEXTAUTH_SECRET=generate-a-long-random-string        # rotating this logs everyone out

# ===== App =====
NEXT_PUBLIC_BASE_URL=https://apocalypsebloxhub.vercel.app
# Optional: paste the token from Google Search Console to verify the domain.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# ===== Key-system providers (Work.ink / Linkvertise / Lootlabs) =====
KEY_GATE_ENFORCED=true
WORKINK_LINK=
LINKVERTISE_LINK=
LINKVERTISE_USER_ID=
LINKVERTISE_ANTIBYPASS_TOKEN=
LOOTLABS_LINK=
LOOTLABS_API_KEY=
LOOTLABS_POSTBACK_SECRET=

# ===== Manual payment details (shown to buyers) =====
NEXT_PUBLIC_PAY_GCASH=
NEXT_PUBLIC_PAY_PAYPAL=
NEXT_PUBLIC_PAY_WISE=
NEXT_PUBLIC_PAY_BANK=

# ===== Email verification (Gmail SMTP) =====
GMAIL_USER=
GMAIL_APP_PASSWORD=

# ===== Assistant LLM (free-tier; comma-separated keys, rotated) =====
# To rotate: create new keys in each provider's dashboard, revoke the old ones,
# then update these here AND in Vercel.
LLM_PROVIDER_ORDER=groq,cerebras,openrouter
GROQ_API_KEYS=            # https://console.groq.com/keys
GROQ_MODEL=llama-3.3-70b-versatile
CEREBRAS_API_KEYS=        # https://cloud.cerebras.ai
CEREBRAS_MODEL=llama-3.3-70b
OPENROUTER_API_KEYS=      # https://openrouter.ai/keys
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# ===== Chatbot web search (Tavily) =====
TAVILY_API_KEYS=          # https://app.tavily.com  (Account -> API Keys)

# ===== Optional: Anthropic as an LLM provider (add 'anthropic' to the order) =====
ANTHROPIC_API_KEY=        # https://console.anthropic.com  (optional)
ASSISTANT_MODEL=claude-haiku-4-5-20251001

# ===== Daily ScriptBlox auto-import cron =====
CRON_SECRET=generate-a-long-random-string
IMPORT_OWNER_EMAIL=you@example.com
CRON_IMPORT_MODE=latest
CRON_IMPORT_PAGES=8
